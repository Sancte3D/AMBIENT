(footprint "Crystal_HC49-US-SMD_ABLS"
  (version 20221018)
  (generator "field_ambience_repo")
  (layer "F.Cu")
  (descr "ABRACON ABLS-Series HC-49/US SMD crystal (11.4x4.7x4.2mm body). Land pattern per ABLS Datasheet Drawing 450669 Rev AD Page 3: pads 5.6x2.1mm at 9.5mm pitch (center-to-center). KiCad-Standard Crystal_SMD_HC49-SD has smaller pads (4.5x2.0mm at 8.5mm pitch) — adequate but below ABRACON recommendation. Use this custom FP for full ABRACON spec.")
  (tags "Crystal HC-49/US HC49 SMD ABLS Abracon")
  (attr smd)
  (property "Reference" "Y**" (at 0 -3.6 0) (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Value" "ABLS-XX.XXXMHZ-XX-T" (at 0 3.6 0) (layer "F.Fab")
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Footprint" "" (at 0 0 0) (layer "F.Fab") hide
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Datasheet" "https://abracon.com/Resonators/ABLS.pdf" (at 0 0 0) (layer "F.Fab") hide
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  ;; Two pads, 5.6mm x 2.1mm, center pitch 9.5mm. Per ABRACON ABLS DS Page 3
  ;; recommended land pattern (5.6mm pad length, 2.1mm pad width, 9.5mm
  ;; pad center-to-center spacing → outer edge to outer edge = 9.5 + 5.6 = 15.1mm
  ;; → matches the body length 11.4mm with 1.85mm pad overhang each side
  ;; for solder fillet formation).
  (pad "1" smd roundrect (at -4.75 0) (size 5.6 2.1) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.1))
  (pad "2" smd roundrect (at  4.75 0) (size 5.6 2.1) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.1))
  ;; Body outline 11.4 x 4.7 mm on F.Fab (per ABRACON DS Mechanical Outline)
  (fp_rect (start -5.7 -2.35) (end 5.7 2.35) (stroke (width 0.1) (type default)) (fill none) (layer "F.Fab"))
  ;; Silkscreen body outline (slightly outside pads, doesn't touch them)
  (fp_line (start -5.8 -2.5) (end -3.0 -2.5) (stroke (width 0.12) (type default)) (layer "F.SilkS"))
  (fp_line (start  3.0 -2.5) (end  5.8 -2.5) (stroke (width 0.12) (type default)) (layer "F.SilkS"))
  (fp_line (start -5.8  2.5) (end -3.0  2.5) (stroke (width 0.12) (type default)) (layer "F.SilkS"))
  (fp_line (start  3.0  2.5) (end  5.8  2.5) (stroke (width 0.12) (type default)) (layer "F.SilkS"))
  (fp_line (start -5.8 -2.5) (end -5.8  2.5) (stroke (width 0.12) (type default)) (layer "F.SilkS"))
  (fp_line (start  5.8 -2.5) (end  5.8  2.5) (stroke (width 0.12) (type default)) (layer "F.SilkS"))
  ;; Pin-1 indicator (small dot near pad 1, off-pad to avoid covering)
  (fp_circle (center -6.3 0) (end -6.1 0) (stroke (width 0.15) (type default)) (fill solid) (layer "F.SilkS"))
  ;; Courtyard per IPC-7351B Class B: 0.25mm clearance around pads/body
  (fp_rect (start -8.0 -2.85) (end 8.0 2.85) (stroke (width 0.05) (type default)) (fill none) (layer "F.CrtYd"))
)
