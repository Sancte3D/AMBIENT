  (attr smd)
  (property "Reference" "SW**" (at 0 -8.5 0) (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Value" "HX 12x12x7.3TPFT-B" (at 0 8.5 0) (layer "F.Fab")
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Footprint" "" (at 0 0 0) (layer "F.Fab") hide
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Datasheet" "https://www.lcsc.com/product-detail/C36498966.html" (at 0 0 0) (layer "F.Fab") hide
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  ;; Pads: 4 corner pads on a 7.0 mm pitch (X & Y), 2.5 x 1.5 mm rect (typical
  ;; for HX 12x12 SMD-4P; verify against EasyEDA pad data before fab if exact
  ;; LCSC drawing changes). SPST: pins 1+2 short, pins 3+4 short, contact closes
  ;; (1/2) ↔ (3/4) on press. Schematic Switch:SW_Push only uses pin 1 and 2 —
  ;; on the footprint they are wired across opposite corners.
  (pad "1" smd roundrect (at -3.5 -3.5) (size 2.5 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (pad "2" smd roundrect (at  3.5  3.5) (size 2.5 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (pad "1" smd roundrect (at  3.5 -3.5) (size 2.5 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (pad "2" smd roundrect (at -3.5  3.5) (size 2.5 1.5) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  ;; Body outline (11.8 x 11.8 mm) — F.Fab
  (fp_rect (start -5.9 -5.9) (end 5.9 5.9) (stroke (width 0.1) (type default)) (fill none) (layer "F.Fab"))
  ;; Silkscreen body outline (slightly outside pads)
  (fp_rect (start -6.05 -6.05) (end 6.05 6.05) (stroke (width 0.12) (type default)) (fill none) (layer "F.SilkS"))
  ;; Pin-1 dot on silkscreen (top-left)
  (fp_circle (center -6.5 -6.5) (end -6.3 -6.5) (stroke (width 0.15) (type default)) (fill solid) (layer "F.SilkS"))
  ;; Courtyard with 0.25 mm clearance per IPC-7351 Class B
  (fp_rect (start -6.4 -6.4) (end 6.4 6.4) (stroke (width 0.05) (type default)) (fill none) (layer "F.CrtYd"))
  ;; Actuator-centre cross on F.Fab (mechanical reference)
  (fp_line (start -1.5 0) (end 1.5 0) (stroke (width 0.05) (type default)) (layer "F.Fab"))
  (fp_line (start 0 -1.5) (end 0 1.5) (stroke (width 0.05) (type default)) (layer "F.Fab"))
)
