(footprint "RotaryEncoder_ALPS_EC11J_SMD"
  (version 20221018)
  (generator "field_ambience_repo")
  (layer "F.Cu")
  (descr "ALPS EC11J series rotary encoder (SMD variant) with push switch. Body 12 x 13.4 mm, vertical shaft 20 mm. Used here for EC11J1525402 (LCSC C209762, 30 detents, 15 pulses, push). PCB land pattern follows ALPS EC11J standard SMD drawing — pad positions are extracted from the EC11 series technical drawing, but the EC11J-specific SMD numbering vs the EC11E-THT variant differs. VERIFY against the EasyEDA C209762 CAD export before fab; this footprint is marked DRAFT until that verification.")
  (tags "ALPS EC11J rotary encoder SMD 30-detent push switch C209762")
  (attr smd)
  (property "Reference" "EN**" (at 0 -9.5 0) (layer "F.SilkS")
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Value" "EC11J1525402" (at 0 9.5 0) (layer "F.Fab")
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Footprint" "" (at 0 0 0) (layer "F.Fab") hide
    (effects (font (size 1.0 1.0) (thickness 0.15))))
  (property "Datasheet" "https://tech.alpsalpine.com/prod/e/html/encoder/incremental/ec11/ec11j1525402.html" (at 0 0 0) (layer "F.Fab") hide
    (effects (font (size 1.0 1.0) (thickness 0.15))))

  ;; ── DRAFT NOTICE ─────────────────────────────────────────────────────
  ;; This is the EC11J SMD land pattern as documented in the ALPS EC11J
  ;; series technical drawing (Drawing No. EC11J series, generic). The
  ;; specific EC11J1525402 variant (LCSC C209762) uses identical mechanics.
  ;; PAD GEOMETRY HERE IS A FIRST-CUT INTERPRETATION — must be cross-checked
  ;; against the EasyEDA C209762 export before any board order. Marked
  ;; FP_DRAFT in the schematic property.
  ;;
  ;; Standard ALPS EC11J SMD pad arrangement (top view, shaft pointing up):
  ;;   3 quadrature/switch SMD pads on the back side (Y = +5 mm row):
  ;;     A, C (common), B  spaced 2.5 mm
  ;;   2 switch SMD pads on the front side (Y = -5 mm row): SW1, SW2
  ;;   2 mounting tabs (mech only, no electrical connection):
  ;;     left tab at X = -6 mm, right tab at X = +6 mm
  ;; ─────────────────────────────────────────────────────────────────────

  ;; Back-row encoder pads (3): A, C-common, B
  (pad "A" smd roundrect (at -2.5  5.0) (size 1.4 1.4) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (pad "C" smd roundrect (at  0.0  5.0) (size 1.4 1.4) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (pad "B" smd roundrect (at  2.5  5.0) (size 1.4 1.4) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  ;; Front-row switch pads (2)
  (pad "S1" smd roundrect (at -2.5 -5.0) (size 1.4 1.4) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  (pad "S2" smd roundrect (at  2.5 -5.0) (size 1.4 1.4) (layers "F.Cu" "F.Paste" "F.Mask") (roundrect_rratio 0.25))
  ;; Mounting tabs (mechanical only — NPTH-like SMD pads for solder anchorage)
  (pad "MT" smd rect (at -6.0  0.0) (size 1.8 3.0) (layers "F.Cu" "F.Paste" "F.Mask"))
  (pad "MT" smd rect (at  6.0  0.0) (size 1.8 3.0) (layers "F.Cu" "F.Paste" "F.Mask"))

  ;; Body outline 12 x 13.4 mm on F.Fab
  (fp_rect (start -6 -6.7) (end 6 6.7) (stroke (width 0.1) (type default)) (fill none) (layer "F.Fab"))
  ;; Silk outline (just outside body)
  (fp_rect (start -6.15 -6.85) (end 6.15 6.85) (stroke (width 0.12) (type default)) (fill none) (layer "F.SilkS"))
  ;; Pin-1 (A) indicator triangle
  (fp_line (start -3.2 6.6) (end -1.8 6.6) (stroke (width 0.15) (type default)) (layer "F.SilkS"))
  (fp_line (start -3.2 6.6) (end -2.5 7.2) (stroke (width 0.15) (type default)) (layer "F.SilkS"))
  (fp_line (start -1.8 6.6) (end -2.5 7.2) (stroke (width 0.15) (type default)) (layer "F.SilkS"))
  ;; Shaft footprint reference (centre, 7 mm diameter envelope on F.Fab)
  (fp_circle (center 0 0) (end 3.5 0) (stroke (width 0.05) (type default)) (fill none) (layer "F.Fab"))
  ;; Courtyard per IPC-7351B Class B (0.5 mm clearance, encoder is taller than usual SMD)
  (fp_rect (start -7 -7.5) (end 7 7.5) (stroke (width 0.05) (type default)) (fill none) (layer "F.CrtYd"))
)
